@@ -0,0 +1,110 @@
+import os
+import sys
+from pathlib import Path
+
+import mlx.core as mx
+import numpy as np
+
+from mflux.models.common.config.model_config import ModelConfig
+from mflux.models.flux2.model.flux2_text_encoder.prompt_encoder import Flux2PromptEncoder
+
+
+UNCENSORED_TE_REPO = "ponpoke/flux2-klein-4b-uncensored-text-encoder"
+UNCENSORED_TE_SUBDIR = "flux2-klein-4b-uncensored-text-encoder"
+UNCENSORED_TE_QUANTS = {
+    "q4_k_m": "flux2-klein-4b-uncensored-q4_k_m.gguf",
+    "q6_k": "flux2-klein-4b-uncensored-q6_k.gguf",
+    "q8_0": "flux2-klein-4b-uncensored-q8_0.gguf",
+}
+
+_TEXT_ENCODER = None
+_TOKENIZER = None
+_TE_DIR = None
+
+
+def _download_uncensored_te(quant: str) -> tuple[str, str]:
+    from huggingface_hub import hf_hub_download
+
+    if quant not in UNCENSORED_TE_QUANTS:
+        raise ValueError(f"unknown uncensored GGUF quant {quant!r}; choose from {list(UNCENSORED_TE_QUANTS)}")
+
+    token = os.environ.get("HF_TOKEN") or os.environ.get("HUGGING_FACE_HUB_TOKEN")
+    gguf_path = hf_hub_download(UNCENSORED_TE_REPO, UNCENSORED_TE_QUANTS[quant], token=token)
+    cfg_path = hf_hub_download(UNCENSORED_TE_REPO, f"{UNCENSORED_TE_SUBDIR}/config.json", token=token)
+    for filename in ("tokenizer.json", "tokenizer_config.json", "generation_config.json", "chat_template.jinja"):
+        try:
+            hf_hub_download(UNCENSORED_TE_REPO, f"{UNCENSORED_TE_SUBDIR}/{filename}", token=token)
+        except Exception:
+            pass
+    return gguf_path, os.path.dirname(cfg_path)
+
+
+def _ensure_loaded():
+    global _TEXT_ENCODER, _TOKENIZER, _TE_DIR
+
+    if _TEXT_ENCODER is not None:
+        return _TEXT_ENCODER, _TOKENIZER, _TE_DIR
+
+    import torch
+    from transformers import AutoTokenizer
+
+    repo_root = Path(os.environ.get("MFLUX_UNCENSORED_GGUF_REPO_ROOT", "."))
+    sys.path.insert(0, str(repo_root))
+    from gguf_qwen3 import load_qwen3_gguf_text_encoder
+
+    quant = os.environ.get("MFLUX_UNCENSORED_GGUF_QUANT", "q4_k_m")
+    device = os.environ.get("MFLUX_UNCENSORED_GGUF_DEVICE", "mps")
+    gguf_path, te_dir = _download_uncensored_te(quant)
+
+    print(f"MFLUX uncensored GGUF TE: loading {quant} on {device}", flush=True)
+    _TEXT_ENCODER, quant_counts = load_qwen3_gguf_text_encoder(
+        gguf_path,
+        te_dir,
+        device=device,
+        compute_dtype=torch.bfloat16,
+    )
+    print(f"MFLUX uncensored GGUF TE tensors: {quant_counts}", flush=True)
+    _TOKENIZER = AutoTokenizer.from_pretrained(te_dir)
+    _TE_DIR = te_dir
+    return _TEXT_ENCODER, _TOKENIZER, _TE_DIR
+
+
+def encode_uncensored_gguf_prompt(
+    prompt: str | list[str],
+    max_sequence_length: int = 512,
+    hidden_state_layers: tuple[int, ...] = (9, 18, 27),
+) -> tuple[mx.array, mx.array]:
+    import torch
+
+    text_encoder, tokenizer, _ = _ensure_loaded()
+    if isinstance(prompt, str):
+        prompt = [prompt]
+
+    prompt = [
+        tokenizer.apply_chat_template(
+            [{"role": "user", "content": p if p is not None else ""}],
+            tokenize=False,
+            add_generation_prompt=True,
+            enable_thinking=False,
+        )
+        for p in prompt
+    ]
+
+    tokens = tokenizer(
+        prompt,
+        padding="max_length",
+        max_length=max_sequence_length,
+        truncation=True,
+        return_tensors="pt",
+    )
+
+    device = next(text_encoder.parameters()).device
+    tokens = {key: value.to(device) for key, value in tokens.items()}
+    with torch.inference_mode():
+        out = text_encoder(**tokens, output_hidden_states=True)
+        prompt_embeds = torch.cat([out.hidden_states[i] for i in hidden_state_layers], dim=-1)
+        prompt_embeds = prompt_embeds.float().cpu().numpy().astype(np.float32)
+
+    prompt_embeds_mx = mx.array(prompt_embeds).astype(ModelConfig.precision)
+    text_ids = Flux2PromptEncoder.prepare_text_ids(prompt_embeds_mx)
+    return prompt_embeds_mx, text_ids
