+_HS_PRINTED = False
+
+
+def _perfect_square(n: int) -> int | None:
+    if n <= 0:
+        return None
+    side = int(n**0.5)
+    return side if side * side == n else None
+
+
+def _infer_text_and_side(seq_len: int) -> tuple[int | None, int | None]:
+    for text_len in (512, 256, 1024, 0):
+        side = _perfect_square(seq_len - text_len)
+        if side is not None:
+            return text_len, side
+
+    for text_len in range(0, min(2048, seq_len) + 1):
+        side = _perfect_square(seq_len - text_len)
+        if side is not None:
+            return text_len, side
+
+    return None, None
+
+
+def _in_frac_window(index: int, total: int, start_frac: float, end_frac: float) -> bool:
+    start = int(total * start_frac)
+    end = int(total * end_frac)
+    return start <= index < max(start + 1, end)
+
+
+def _downsample_image_tokens(img: mx.array, side: int, stride: int) -> mx.array:
+    batch, _, dim = img.shape
+    low_side = side // stride
+    grid = img.reshape(batch, side, side, dim)
+    low = grid.reshape(batch, low_side, stride, low_side, stride, dim).mean(axis=(2, 4))
+    return low.reshape(batch, low_side * low_side, dim)
+
+
+def _upsample_image_tokens(img_low: mx.array, side: int, stride: int) -> mx.array:
+    batch, _, dim = img_low.shape
+    low_side = side // stride
+    grid = img_low.reshape(batch, low_side, low_side, dim)
+    up = mx.repeat(mx.repeat(grid, stride, axis=1), stride, axis=2)
+    return up.reshape(batch, side * side, dim)
+
+
+def _reduced_rotary_emb(image_rotary_emb, text_len: int, side: int, stride: int):
+    if image_rotary_emb is None:
+        return None
+
+    low_side = side // stride
+    yy = mx.arange(low_side, dtype=mx.int32) * stride + stride // 2
+    xx = mx.arange(low_side, dtype=mx.int32) * stride + stride // 2
+    grid_y, grid_x = mx.meshgrid(yy, xx, indexing="ij")
+    image_idx = (grid_y * side + grid_x).reshape(-1)
+
+    reduced = []
+    for emb in image_rotary_emb:
+        text_emb = emb[:text_len]
+        img_emb = emb[text_len:][image_idx]
+        reduced.append(mx.concatenate([text_emb, img_emb], axis=0))
+    return tuple(reduced)
+
