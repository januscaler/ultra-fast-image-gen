+
+        call_index = getattr(self, "_mflux_hs_call_index", None)
+        block_index = getattr(self, "_mflux_hs_block_index", None)
+        block_total = getattr(self, "_mflux_hs_block_total", None)
+        if call_index is None or block_index is None or block_total is None:
+            return False
+
+        if call_index < MFLUX_HS_SKIP_TRANSFORMER_FORWARDS or call_index >= MFLUX_HS_MAX_TRANSFORMER_FORWARD:
+            return False
+
+        if not _in_frac_window(block_index, block_total, MFLUX_HS_SINGLE_START_FRAC, MFLUX_HS_SINGLE_END_FRAC):
+            return False
+
+        text_len, side = _infer_text_and_side(hidden_states.shape[1])
+        return text_len is not None and side % MFLUX_HS_STRIDE == 0
