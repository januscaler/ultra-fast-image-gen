+MFLUX_HS_SKIP_TRANSFORMER_FORWARDS = int(os.environ.get("MFLUX_HS_SKIP_TRANSFORMER_FORWARDS", "0"))
+MFLUX_HS_MAX_TRANSFORMER_FORWARD = int(os.environ.get("MFLUX_HS_MAX_TRANSFORMER_FORWARD", "0"))
+MFLUX_HS_SINGLE_START_FRAC = float(os.environ.get("MFLUX_HS_SINGLE_START_FRAC", "0.0"))
