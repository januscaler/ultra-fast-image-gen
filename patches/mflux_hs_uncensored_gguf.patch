+
+        if MFLUX_HS_VERBOSE and not _HS_PRINTED:
+            low_side = side // MFLUX_HS_STRIDE
+            before = hidden_states.shape[1]
+            after = text_len + low_side * low_side
+            print(f"MFLUX_HS active: {before} -> {after} tokens, stride={MFLUX_HS_STRIDE}", flush=True)
+            _HS_PRINTED = True
+
+        text = hidden_states[:, :text_len]
+        img = hidden_states[:, text_len:]
+        img_low = _downsample_image_tokens(img, side, MFLUX_HS_STRIDE)
+        reduced_hidden = mx.concatenate([text, img_low], axis=1)
+        reduced_rotary = _reduced_rotary_emb(image_rotary_emb, text_len, side, MFLUX_HS_STRIDE)
+
+        mod_shift, mod_scale, mod_gate = temb_mod_params
+        norm_hidden_states = self.norm(reduced_hidden)
+        norm_hidden_states = (1 + mod_scale) * norm_hidden_states + mod_shift
+        out = reduced_hidden + mod_gate * self.attn(norm_hidden_states, reduced_rotary)
+
+        out_text = out[:, :text_len]
+        out_img_low = out[:, text_len:]
