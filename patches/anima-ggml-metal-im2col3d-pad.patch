index 2074211..0b15ee5 100644
--- a/src/ggml-metal/ggml-metal.metal
+++ b/src/ggml-metal/ggml-metal.metal
@@ -4478,0 +4479,60 @@ template [[host_name("kernel_im2col_f16")]] kernel im2col_t kernel_im2col<half>;
+template <typename T>
+kernel void kernel_op_im2col_3d(
+        constant ggml_metal_kargs_im2col_3d & args,
+        device   const uchar * src1c,
+        device         char  * dstc,
+        uint tpig[[thread_position_in_grid]]) {
+    const uint64_t total = args.N * args.OD * args.OH * args.OW;
+    if (tpig >= total) {
+        return;
+    }
+
+    device T * dst = (device T *) dstc;
+
+    uint64_t idx = tpig;
+
+    const uint64_t iow = idx % args.OW;
+    idx /= args.OW;
+
+    const uint64_t ioh = idx % args.OH;
+    idx /= args.OH;
+
+    const uint64_t iod = idx % args.OD;
+    idx /= args.OD;
+
+    const uint64_t in = idx;
+
+    uint64_t dst_base_offset = ((in*args.OD + iod)*args.OH + ioh)*args.OW + iow;
+    dst_base_offset *= args.IC_KD_KH_KW;
+
+    for (uint32_t iic = 0; iic < args.IC; ++iic) {
+        const uint64_t src_offset0 = (in*args.IC + iic)*args.nb13;
+
+        for (uint32_t ikd = 0; ikd < args.KD; ++ikd) {
+            for (uint32_t ikh = 0; ikh < args.KH; ++ikh) {
+                for (uint32_t ikw = 0; ikw < args.KW; ++ikw) {
+                    const int32_t iiw = (int32_t) iow*args.s0 + ikw*args.d0 - args.p0;
+                    const int32_t iih = (int32_t) ioh*args.s1 + ikh*args.d1 - args.p1;
+                    const int32_t iid = (int32_t) iod*args.s2 + ikd*args.d2 - args.p2;
+
+                    const uint64_t dst_idx = dst_base_offset + iic*args.KD_KH_KW + ikd*args.KH_KW + ikh*args.KW + ikw;
+
+                    T val = T(0.0f);
+                    if (iid >= 0 && iid < args.ID && iih >= 0 && iih < args.IH && iiw >= 0 && iiw < args.IW) {
+                        const uint64_t src_offset = src_offset0 + iid*args.nb12 + iih*args.nb11 + iiw*args.nb10;
+                        const device const uchar * src_bytes = src1c + src_offset;
+                        val = T(*reinterpret_cast<const device float *>(src_bytes));
+                    }
+
+                    dst[dst_idx] = val;
+                }
+            }
+        }
+    }
+}
+
+typedef decltype(kernel_op_im2col_3d<float>) kernel_op_im2col_3d_t;
+
+template [[host_name("kernel_op_im2col_3d_f32")]] kernel kernel_op_im2col_3d_t kernel_op_im2col_3d<float>;
+template [[host_name("kernel_op_im2col_3d_f16")]] kernel kernel_op_im2col_3d_t kernel_op_im2col_3d<half>;
+
